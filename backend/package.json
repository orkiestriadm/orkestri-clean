{
    "name": "orkestri-api",
    "version": "1.0.0",
    "scripts": {
        "build": "nest build",
        "start": "node dist/main",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "smoke:health": "node scripts/smoke-health.js"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^10.0.0",
        "@nestjs/passport": "^10.0.0",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/schedule": "^4.0.0",
        "@prisma/client": "^5.0.0",
        "@types/uuid": "^10.0.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "cookie-parser": "^1.4.7",
        "helmet": "^7.0.0",
        "ioredis": "^5.3.2",
        "mercadopago": "^2.0.15",
        "otpauth": "^9.3.4",
        "passport": "^0.6.0",
        "passport-jwt": "^4.0.1",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.1.13",
        "resend": "^4.0.0",
        "rxjs": "^7.8.0",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.8",
        "@types/cron": "^2.4.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@types/passport-jwt": "^3.0.9",
        "jest": "^29.7.0",
        "prisma": "^5.0.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.ts",
            "!**/*.module.ts",
            "!main.ts"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
