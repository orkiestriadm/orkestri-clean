generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TaskStatus {
  A_FAZER
  EM_ANDAMENTO
  EM_REVISAO
  CONCLUIDA
  CANCELADA
}

enum EventType {
  PESSOAL
  REUNIAO
  PROJETO
  EXTERNO
  COMPROMISSO
  LEMBRETE
}

enum NoteType {
  TEXTO
  CHECKLIST
}

enum Recurrence {
  DIARIA
  SEMANAL
  QUINZENAL
  MENSAL
}

enum ProjectTipo {
  PROJETO
  NEGOCIO
}

// ── Multi-tenancy ──────────────────────────────────────────────────────────────

model Organization {
  id                String   @id @default(uuid())
  nome              String
  slug              String   @unique
  plano             String   @default("starter")
  ativo             Boolean  @default(true)
  // Cadastro da empresa
  cnpj              String?
  nomeFantasia      String?  @map("nome_fantasia")
  segmento          String?
  site              String?
  emailContato      String?  @map("email_contato")
  telefone          String?
  responsavelNome   String?  @map("responsavel_nome")
  cep               String?
  endereco          String?
  cidade            String?
  estado            String?
  observacoes       String?
  // CRM ↔ Tenant link
  crmClienteId      String?  @unique @map("crm_cliente_id")
  statusComercial   String?  @map("status_comercial")
  statusOperacional String?  @map("status_operacional")
  modulosAtivos     String[] @default([]) @map("modulos_ativos")
  criadoEm          DateTime @default(now()) @map("criado_em")
  atualizadoEm      DateTime @updatedAt @map("atualizado_em")

  users             User[]
  chamados          Chamado[]
  clientes          Cliente[]
  contratos         Contrato[]
  faturas           Fatura[]
  projetos          Project[]
  notas             Note[]
  noteLabels        NoteLabel[]
  eventos           Event[]
  automacoes        Automacao[]
  ativos            Ativo[]
  categoriasAtivo   CategoriaAtivo[]
  artigos           ArtigoConhecimento[]
  categoriasConhec  CategoriaConhecimento[]
  suppliers         Supplier[]
  slaRegras         SlaRegra[]
  alertConfigs      AlertConfig[]
  setores           Setor[]
  auditLogs         AuditLog[]
  orcamentoCiclos   OrcamentoCiclo[]
  centrosCusto      CentroCusto[]
  categoriasOrc     CategoriaOrcamento[]
  fornecedoresOrc   FornecedorOrcamento[]
  sistemaConfigs    SistemaConfig[]
  apontamentosHoras ApontamentoHoras[]
  whatsappConfig    OrgWhatsappConfig?
  cadastroRequests  CadastroRequest[]       @relation("CadReqOrg")
  collaborators     Collaborator[]          @relation("OrgCollaborators")
  skills            Skill[]                 @relation("OrgSkills")
  ausencias         Ausencia[]              @relation("OrgAusencias")
  workflowRequests  WorkflowRequest[]       @relation("OrgWorkflowRequests")
  squads            Squad[]                 @relation("OrgSquads")
  aprovadoresSetor  AprovadorSetor[]
  billing           OrgBilling?
  workflowTemplates  WorkflowTemplate[]  @relation("OrgWorkflowTemplates")
  chamadoTemplates   ChamadoTemplate[]   @relation("OrgChamadoTemplates")
  webhooks           Webhook[]
  monitoringKey      String?  @map("monitoring_key")
  pingLogs           PingLog[]

  // ── Chamados v2 (campos custom) ──
  chamadoCustomFields ChamadoCustomField[]

  // ── Monitoramento Operacional (modulo independente) ──
  monAssets       MonAsset[]
  monUnidades     MonUnidade[]
  monStatusEvents MonStatusEvent[]
  monMaps         MonMap[]
  monAlertChannels MonAlertChannel[]
  monAlertRules   MonAlertRule[]
  monSlaMetas     MonSlaMeta[]
  monServices     MonService[]
  monServiceEvents MonServiceEvent[]
  osaMonitores    OsaMonitor[]

  // ── Financeiro ──
  contasPagar     ContaPagar[]

  // ── Gestão de Frotas ──
  veiculos           Veiculo[]
  motoristas         Motorista[]
  categoriasVeiculo  CategoriaVeiculo[]
  pneus              Pneu[]
  revisoesVeiculo    RevisaoVeiculo[]
  manutencoesVeiculo ManutencaoVeiculo[]
  documentosVeiculo  DocumentoVeiculo[]
  abastecimentos     Abastecimento[]
  condutoresVeiculo  VeiculoCondutor[]
  motoristaRenovacoes MotoristaCnhRenovacao[]
  motoristaAnexos     MotoristaAnexo[]
  pneuEventos         PneuEvento[]
  pneuLayouts         PneuLayout[]
  planosRevisao       PlanoRevisao[]
  manutencaoMaoObra   ManutencaoMaoObra[]
  manutencaoAnexos    ManutencaoAnexo[]
  documentoAnexos     DocumentoAnexo[]
  reportSchedules     FrotaReportSchedule[]

  @@map("organizations")
}


model OrgWhatsappConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique @map("organization_id")
  instanceName   String       @unique @map("instance_name")
  phoneNumber    String?      @map("phone_number")
  conectado      Boolean      @default(false)
  ultimaConexao  DateTime?    @map("ultima_conexao")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  atualizadoEm   DateTime     @updatedAt @map("atualizado_em")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_whatsapp_configs")
}

model SuperAdmin {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  criadoEm DateTime @default(now()) @map("criado_em")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("super_admins")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  nome             String
  email            String
  senhaHash        String    @map("senha_hash")
  ativo            Boolean   @default(true)
  avatar           String?
  ultimoLogin      DateTime? @map("ultimo_login")
  primeiroAcesso   Boolean   @default(true) @map("primeiro_acesso")
  bloqueado        Boolean   @default(false) @map("bloqueado")
  tentativasFalhas Int       @default(0) @map("tentativas_falhas")
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  organization              Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  superAdmin                SuperAdmin?
  userRoles                 UserRole[]               @relation("UserToRoles")
  rolesAtrib                UserRole[]               @relation("AtribuidoPor")
  sessions                  UserSession[]
  eventsOwner               Event[]                  @relation("EventOwner")
  eventsCriados             Event[]                  @relation("EventCreator")
  eventParticipants         EventParticipant[]
  projectsOwner             Project[]                @relation("ProjectOwner")
  projectMembers            ProjectMember[]
  tasksAssignee             Task[]                   @relation("TaskAssignee")
  tasksCriadas              Task[]                   @relation("TaskCreator")
  taskComments              TaskComment[]
  notes                     Note[]
  noteLabels                NoteLabel[]
  noteCollabs               NoteCollaborator[]
  checklistItems            ChecklistItem[]          @relation("ChecklistAssignee")
  dailyTasks                DailyTask[]
  notifications             Notification[]
  auditLogs                 AuditLog[]
  profile                   UserProfile?
  chamadosSolicitados       Chamado[]                @relation("ChamadoSolicitante")
  chamadosAtendidos         Chamado[]                @relation("ChamadoAtendente")
  comentariosChamado        ChamadoComentario[]
  chamadoAuditorias         ChamadoAuditoria[]
  chamadoWatchers           ChamadoWatcher[]         @relation("ChamadoWatcher")
  chamadoSubtasks           ChamadoSubtask[]         @relation("ChamadoSubtask")
  chamadoLinksCriados       ChamadoLink[]            @relation("ChamadoLinkCreator")
  permissionOverrides       UserPermissionOverride[]
  passwordResetOtps         PasswordResetOtp[]
  clientesResponsavel       Cliente[]                @relation("ClienteResponsavel")
  clienteTimelines          ClienteTimeline[]
  ciclosAprovados           OrcamentoCiclo[]         @relation("CicloAprovador")
  centrosCustoResponsavel   CentroCusto[]            @relation("CentroCustoResp")
  itensOrcamentoCriados     ItemOrcamento[]          @relation("ItemCriador")
  lancamentosOrcamento      ItemOrcamentoMes[]       @relation("LancadoPor")
  aprovacoesSolicitadas     AprovacaoOrcamento[]     @relation("AprovSolicitante")
  aprovacoesDecididas       AprovacaoOrcamento[]     @relation("AprovDecisao")
  orcamentoTimelines        OrcamentoTimeline[]      @relation("OrcTimeline")
  suppliersCriados          Supplier[]               @relation("SupplierCriador")
  supplierHistory           SupplierHistory[]
  supplierDocuments         SupplierDocument[]
  setoresResponsavel        Setor[]                  @relation("SetorResponsavel")
  artigosConhecimento       ArtigoConhecimento[]     @relation("ArtigoAutor")
  ativosResponsavel         Ativo[]                  @relation("AtivoResponsavel")
  monAssetsResponsavel      MonAsset[]               @relation("MonAssetResponsavel")
  transferenciasRealizadas  TransferenciaAtivo[]     @relation("TransfPor")
  transferenciasRecebidas   TransferenciaAtivo[]     @relation("TransfPara")
  transferenciasEnviadas    TransferenciaAtivo[]     @relation("TransfDe")
  apontamentosHoras         ApontamentoHoras[]
  contratosResponsavel      Contrato[]               @relation("ContratoResponsavel")
  faturas                   Fatura[]                 @relation("FaturaCriador")
  cadastroRequestsAprovados CadastroRequest[]        @relation("CadReqAprovador")
  cadastroRequestsCriados   CadastroRequest[]        @relation("CadReqCriador")
  collaborator              Collaborator?            @relation("UserCollaborator")
  ausenciasSolicitadas      Ausencia[]               @relation("AusenciaSolicitante")
  ausenciasAprovadas        Ausencia[]               @relation("AusenciaAprovador")
  wfRequestsSolicitadas     WorkflowRequest[]        @relation("WfReqSolicitante")
  wfRequestsParaAprovar     WorkflowRequest[]        @relation("WfReqAprovadorAtual")
  wfRequestsAprovadas       WorkflowRequest[]        @relation("WfReqAprovador")
  wfRequestsRejeitadas      WorkflowRequest[]        @relation("WfReqRejeitador")
  wfApprovals               WorkflowApproval[]       @relation("WfApprovalAprovador")
  aprovadoresPrimarioDeSetor AprovadorSetor[]        @relation("AprovadorPrimario")
  aprovadoresBackupDeSetor   AprovadorSetor[]        @relation("AprovadorBackup")
  aprovadoresConfigurados    AprovadorSetor[]        @relation("AprovadorConfigurador")
  workflowTemplatesCriados   WorkflowTemplate[]      @relation("WfTemplateCriador")
  chamadoTemplatesCriados    ChamadoTemplate[]       @relation("ChamadoTemplateCriador")
  chamadoAnexosUploads       ChamadoAnexo[]          @relation("AnexoUploader")
  veiculosResponsavel        Veiculo[]               @relation("VeiculoResponsavel")
  manutencoesSolicitadas     ManutencaoVeiculo[]     @relation("ManutencaoSolicitante")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

// ── Orçamento ──────────────────────────────────────────────────────────────────

model OrcamentoCiclo {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  ano            Int
  descricao      String?
  status         String          @default("rascunho")
  aprovadoPorId  String?         @map("aprovado_por_id")
  aprovadoPor    User?           @relation("CicloAprovador", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itens          ItemOrcamento[]
  criadoEm       DateTime        @default(now()) @map("criado_em")
  atualizadoEm   DateTime        @updatedAt @map("atualizado_em")

  @@unique([organizationId, ano])
  @@map("orcamento_ciclos")
}

model CentroCusto {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  codigo         String
  nome           String
  descricao      String?
  cor            String          @default("#a78bfa")
  ativo          Boolean         @default(true)
  responsavelId  String?         @map("responsavel_id")
  responsavel    User?           @relation("CentroCustoResp", fields: [responsavelId], references: [id], onDelete: SetNull)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itens          ItemOrcamento[]
  veiculos       Veiculo[]
  criadoEm       DateTime        @default(now()) @map("criado_em")

  @@unique([organizationId, codigo])
  @@map("centros_custo")
}

model CategoriaOrcamento {
  id             String               @id @default(uuid())
  organizationId String               @map("organization_id")
  tipo           String
  codigo         String
  nome           String
  cor            String               @default("#a78bfa")
  icone          String?
  paiId          String?              @map("pai_id")
  pai            CategoriaOrcamento?  @relation("CatPai", fields: [paiId], references: [id])
  filhas         CategoriaOrcamento[] @relation("CatPai")
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itens          ItemOrcamento[]
  criadoEm       DateTime             @default(now()) @map("criado_em")

  @@index([organizationId])
  @@map("categorias_orcamento")
}

model FornecedorOrcamento {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  nome           String
  cnpj           String?
  email          String?
  telefone       String?
  segmento       String?
  ativo          Boolean         @default(true)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itens          ItemOrcamento[]
  criadoEm       DateTime        @default(now()) @map("criado_em")

  @@index([organizationId])
  @@map("fornecedores_orcamento")
}

model ItemOrcamento {
  id            String               @id @default(uuid())
  cicloId       String               @map("ciclo_id")
  ciclo         OrcamentoCiclo       @relation(fields: [cicloId], references: [id])
  centroCustoId String?              @map("centro_custo_id")
  centroCusto   CentroCusto?         @relation(fields: [centroCustoId], references: [id])
  categoriaId   String               @map("categoria_id")
  categoria     CategoriaOrcamento   @relation(fields: [categoriaId], references: [id])
  tipo          String
  nome          String
  descricao     String?
  fornecedorId  String?              @map("fornecedor_id")
  fornecedor    FornecedorOrcamento? @relation(fields: [fornecedorId], references: [id])
  supplierId    String?              @map("supplier_id")
  supplier      Supplier?            @relation("ItemSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  recorrente    Boolean              @default(false)
  periodicidade String               @default("mensal")
  status        String               @default("ativo")
  observacoes   String?
  meses         ItemOrcamentoMes[]
  timeline      OrcamentoTimeline[]
  aprovacoes    AprovacaoOrcamento[]
  criadoPorId   String               @map("criado_por_id")
  criadoPor     User                 @relation("ItemCriador", fields: [criadoPorId], references: [id])
  criadoEm      DateTime             @default(now()) @map("criado_em")
  atualizadoEm  DateTime             @updatedAt @map("atualizado_em")

  @@map("itens_orcamento")
}

model ItemOrcamentoMes {
  id             String        @id @default(uuid())
  itemId         String        @map("item_id")
  item           ItemOrcamento @relation(fields: [itemId], references: [id], onDelete: Cascade)
  mes            Int
  valorPrevisto  Float         @default(0) @map("valor_previsto")
  valorRealizado Float?        @map("valor_realizado")
  status         String        @default("pendente")
  observacoes    String?
  lancadoPorId   String?       @map("lancado_por_id")
  lancadoPor     User?         @relation("LancadoPor", fields: [lancadoPorId], references: [id], onDelete: SetNull)
  lancadoEm      DateTime?     @map("lancado_em")

  @@unique([itemId, mes])
  @@map("itens_orcamento_mes")
}

model AprovacaoOrcamento {
  id              String         @id @default(uuid())
  itemId          String?        @map("item_id")
  item            ItemOrcamento? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tipo            String
  status          String         @default("pendente")
  solicitadoPorId String         @map("solicitado_por_id")
  solicitadoPor   User           @relation("AprovSolicitante", fields: [solicitadoPorId], references: [id])
  aprovadoPorId   String?        @map("aprovado_por_id")
  aprovadoPor     User?          @relation("AprovDecisao", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  observacoes     String?
  criadoEm        DateTime       @default(now()) @map("criado_em")
  resolvidoEm     DateTime?      @map("resolvido_em")

  @@map("aprovacoes_orcamento")
}

model OrcamentoTimeline {
  id        String        @id @default(uuid())
  itemId    String        @map("item_id")
  item      ItemOrcamento @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tipo      String
  titulo    String
  descricao String?
  userId    String?       @map("user_id")
  user      User?         @relation("OrcTimeline", fields: [userId], references: [id], onDelete: SetNull)
  criadoEm  DateTime      @default(now()) @map("criado_em")

  @@map("orcamento_timeline")
}

// ── Auth / Access ──────────────────────────────────────────────────────────────

model UserRequest {
  id              String    @id @default(uuid())
  organizationId  String?   @map("organization_id")
  nome            String
  email           String
  whatsapp        String?
  cargo           String?
  departamento    String?
  empresa         String?
  motivacao       String?
  status          String    @default("PENDENTE")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  // ── Workforce (preenchidos na aprovação) ─────────────────
  setorId         String?   @map("setor_id")
  gestorId        String?   @map("gestor_id")
  jornadaHorasDia Float?    @map("jornada_horas_dia")
  squad           String?
  perfilRoleId    String?   @map("perfil_role_id")
  senioridade     String?
  tipoVinculo     String?   @map("tipo_vinculo")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  @@map("user_requests")
}

// ── Workforce: Squads ──────────────────────────────────────────────────────
model Squad {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  nome           String
  descricao      String?
  cor            String?
  liderId        String?  @map("lider_id")
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  organization Organization  @relation("OrgSquads", fields: [organizationId], references: [id], onDelete: Cascade)
  lider        Collaborator? @relation("SquadLider", fields: [liderId], references: [id], onDelete: SetNull)
  members      SquadMember[]

  @@unique([organizationId, nome])
  @@index([organizationId])
  @@map("squads")
}

model SquadMember {
  id              String   @id @default(uuid())
  squadId         String   @map("squad_id")
  collaboratorId  String   @map("collaborator_id")
  alocacaoPercent Int      @default(100) @map("alocacao_percent")
  papel           String   @default("membro")
  criadoEm        DateTime @default(now()) @map("criado_em")

  squad        Squad        @relation(fields: [squadId], references: [id], onDelete: Cascade)
  collaborator Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@unique([squadId, collaboratorId])
  @@index([squadId])
  @@index([collaboratorId])
  @@map("squad_members")
}

// ── Workforce: Workflows de Aprovação ──────────────────────────────────────
model WorkflowRequest {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  solicitanteId    String    @map("solicitante_id")
  tipo             String // despesa | horas_extra | alteracao_cadastral | folga_compensatoria | outro
  titulo           String
  descricao        String?   @db.Text
  payload          Json?
  valor            Float?
  status           String    @default("PENDENTE") // PENDENTE | APROVADA | REJEITADA | CANCELADA
  aprovadorAtualId String?   @map("aprovador_atual_id")
  aprovadoPorId    String?   @map("aprovado_por_id")
  aprovadoEm       DateTime? @map("aprovado_em")
  rejeitadoPorId   String?   @map("rejeitado_por_id")
  rejeitadoEm      DateTime? @map("rejeitado_em")
  motivoRejeicao   String?   @map("motivo_rejeicao")
  ultimoLembreteEm DateTime? @map("ultimo_lembrete_em")
  escaladoEm       DateTime? @map("escalado_em")
  criadoEm         DateTime  @default(now()) @map("criado_em")
  atualizadoEm     DateTime  @updatedAt @map("atualizado_em")

  organization   Organization       @relation("OrgWorkflowRequests", fields: [organizationId], references: [id], onDelete: Cascade)
  solicitante    User               @relation("WfReqSolicitante", fields: [solicitanteId], references: [id], onDelete: Cascade)
  aprovadorAtual User?              @relation("WfReqAprovadorAtual", fields: [aprovadorAtualId], references: [id], onDelete: SetNull)
  aprovadoPor    User?              @relation("WfReqAprovador", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  rejeitadoPor   User?              @relation("WfReqRejeitador", fields: [rejeitadoPorId], references: [id], onDelete: SetNull)
  aprovacoes     WorkflowApproval[]

  @@index([organizationId])
  @@index([solicitanteId])
  @@index([aprovadorAtualId])
  @@index([status])
  @@index([tipo])
  @@map("workflow_requests")
}

model WorkflowApproval {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  aprovadorId String   @map("aprovador_id")
  nivel       Int      @default(1)
  decisao     String // APROVADO | REJEITADO | ESCALADO
  observacoes String?
  criadoEm    DateTime @default(now()) @map("criado_em")

  request   WorkflowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  aprovador User            @relation("WfApprovalAprovador", fields: [aprovadorId], references: [id])

  @@index([requestId])
  @@index([aprovadorId])
  @@map("workflow_approvals")
}

// ── Workflow Templates (Fase 3 — Workflow Visual) ──────────────────────────────
model WorkflowTemplate {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  nome           String
  descricao      String?
  tipo           String   @default("outro") // ti | rh | financeiro | juridico | compras | facilities | outro
  icone          String?
  cor            String   @default("#a78bfa")
  ativo          Boolean  @default(true)
  etapas         Json     @default("[]")
  criadoPorId    String   @map("criado_por_id")
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  organization Organization @relation("OrgWorkflowTemplates", fields: [organizationId], references: [id], onDelete: Cascade)
  criadoPor    User         @relation("WfTemplateCriador", fields: [criadoPorId], references: [id])

  @@index([organizationId])
  @@map("workflow_templates")
}

// Matriz de aprovadores por setor — 1 primário + 1 backup com vigência.
// Quando a vigência do backup está ativa (hoje entre inicio e fim), todas as
// solicitações novas (e os lembretes que escalam) vão para o backup. Fora da
// vigência, voltam ao primário automaticamente.
model AprovadorSetor {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  setorId           String    @unique @map("setor_id")
  aprovadorId       String    @map("aprovador_id")
  backupAprovadorId String?   @map("backup_aprovador_id")
  backupInicio      DateTime? @map("backup_inicio")
  backupFim         DateTime? @map("backup_fim")
  configuradoPorId  String?   @map("configurado_por_id")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  setor            Setor        @relation(fields: [setorId], references: [id], onDelete: Cascade)
  aprovador        User         @relation("AprovadorPrimario", fields: [aprovadorId], references: [id], onDelete: Cascade)
  backupAprovador  User?        @relation("AprovadorBackup",   fields: [backupAprovadorId], references: [id], onDelete: SetNull)
  configuradoPor   User?        @relation("AprovadorConfigurador", fields: [configuradoPorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([aprovadorId])
  @@index([backupAprovadorId])
  @@map("aprovadores_setor")
}

// ── Workforce: Ausências ───────────────────────────────────────────────────
model Ausencia {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  collaboratorId  String    @map("collaborator_id")
  tipo            String // ferias | atestado | folga | licenca | banco_horas | outro
  dataInicio      DateTime  @map("data_inicio")
  dataFim         DateTime  @map("data_fim")
  diaInteiro      Boolean   @default(true) @map("dia_inteiro")
  horasDia        Float?    @map("horas_dia") // se dia_inteiro=false, horas que serão deduzidas por dia
  descricao       String?
  documentoUrl    String?   @map("documento_url")
  status          String    @default("PENDENTE") // PENDENTE | APROVADA | REJEITADA | CANCELADA
  solicitadaPorId String?   @map("solicitada_por_id")
  aprovadaPorId   String?   @map("aprovada_por_id")
  aprovadaEm      DateTime? @map("aprovada_em")
  motivoRejeicao  String?   @map("motivo_rejeicao")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  organization  Organization @relation("OrgAusencias", fields: [organizationId], references: [id], onDelete: Cascade)
  collaborator  Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  solicitadaPor User?        @relation("AusenciaSolicitante", fields: [solicitadaPorId], references: [id], onDelete: SetNull)
  aprovadaPor   User?        @relation("AusenciaAprovador", fields: [aprovadaPorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([collaboratorId])
  @@index([dataInicio])
  @@index([status])
  @@map("ausencias")
}

// ── Workforce: Skills ──────────────────────────────────────────────────────
model Skill {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  nome           String
  categoria      String?
  descricao      String?
  cor            String?
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  organization  Organization        @relation("OrgSkills", fields: [organizationId], references: [id], onDelete: Cascade)
  collaborators CollaboratorSkill[]
  chamados      Chamado[]           @relation("ChamadoSkill")

  @@unique([organizationId, nome])
  @@index([organizationId])
  @@index([categoria])
  @@map("skills")
}

model CollaboratorSkill {
  id             String    @id @default(uuid())
  collaboratorId String    @map("collaborator_id")
  skillId        String    @map("skill_id")
  nivel          String    @default("pleno") // junior | pleno | senior | especialista
  certificadoEm  DateTime? @map("certificado_em")
  validade       DateTime?
  observacoes    String?
  criadoEm       DateTime  @default(now()) @map("criado_em")

  collaborator Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  skill        Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([collaboratorId, skillId])
  @@index([collaboratorId])
  @@index([skillId])
  @@map("collaborator_skills")
}

// ── Workforce / Colaboradores ──────────────────────────────────────────────
model Collaborator {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  userId           String   @unique @map("user_id")
  matricula        String?
  fotoUrl          String?  @map("foto_url")
  emailCorporativo String?  @map("email_corporativo")
  telefone         String?
  // Estrutura organizacional
  cargo            String?
  departamento     String?
  setorId          String?  @map("setor_id")
  squad            String?
  especialidade    String?
  senioridade      String?
  gestorId         String?  @map("gestor_id")
  // Operacionais
  jornadaHorasDia  Float?   @map("jornada_horas_dia")
  jornadaHorasMes  Float?   @map("jornada_horas_mes")
  turno            String?
  escala           String?
  tipoVinculo      String?  @map("tipo_vinculo")
  // Futuro
  skills           Json?
  certificacoes    Json?
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now()) @map("criado_em")
  atualizadoEm     DateTime @updatedAt @map("atualizado_em")

  organization     Organization        @relation("OrgCollaborators", fields: [organizationId], references: [id], onDelete: Cascade)
  user             User                @relation("UserCollaborator", fields: [userId], references: [id], onDelete: Cascade)
  setor            Setor?              @relation("SetorCollaborators", fields: [setorId], references: [id], onDelete: SetNull)
  gestor           Collaborator?       @relation("CollabHierarchy", fields: [gestorId], references: [id], onDelete: SetNull)
  liderados        Collaborator[]      @relation("CollabHierarchy")
  collabSkills     CollaboratorSkill[]
  ausencias        Ausencia[]
  squadsLiderados  Squad[]             @relation("SquadLider")
  squadMemberships SquadMember[]

  @@unique([organizationId, matricula])
  @@index([organizationId])
  @@index([setorId])
  @@index([gestorId])
  @@map("collaborators")
}

model PasswordResetOtp {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  otpCode      String   @map("otp_code")
  otpExpiresAt DateTime @map("otp_expires_at")
  otpAttempts  Int      @default(0) @map("otp_attempts")
  used         Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_otps")
}

// ── Auto-signup (landing page → MP → provisionamento) ─────────────────────────
model BillingSignupSession {
  id             String   @id @default(uuid())
  // Token enviado no back_url do MP; usado para polling de status
  token          String   @unique @default(uuid())

  plano          String
  payerEmail     String   @map("payer_email")
  orgNome        String   @map("org_nome")
  orgSlug        String   @map("org_slug")
  adminNome      String   @map("admin_nome")
  adminSenhaHash String   @map("admin_senha_hash")

  mpPreapprovalId String? @map("mp_preapproval_id")
  mpCheckoutUrl   String? @map("mp_checkout_url")

  // pending | redirected | paid | completed | failed | expired
  status         String   @default("pending")

  organizationId String?  @map("organization_id")
  criadoEm       DateTime @default(now()) @map("criado_em")
  expiresAt      DateTime @map("expires_at")

  @@index([token])
  @@index([mpPreapprovalId])
  @@map("billing_signup_sessions")
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  whatsapp        String?
  whatsappAlertas Boolean  @default(false) @map("whatsapp_alertas")
  criadoEm        DateTime @default(now()) @map("criado_em")
  twoFactorSecret String?  @map("two_factor_secret")
  twoFactorAtivo  Boolean  @default(false) @map("two_factor_ativo")
  twoFactorBackup String?  @map("two_factor_backup")
  statusOnline    String?  @default("disponivel") @map("status_online")
  setorId         String?  @map("setor_id")
  cargo           String?
  telefone        String?
  modulos         String   @default("[\"projetos\",\"keep\",\"gantt\",\"relatorios\"]")
  setor           Setor?   @relation(fields: [setorId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Role {
  id              String           @id @default(uuid())
  nome            String           @unique
  descricao       String?
  isMaster        Boolean          @default(false) @map("is_master")
  nivel           Int              @default(0)
  criadoEm        DateTime         @default(now()) @map("criado_em")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId         String   @map("user_id")
  roleId         String   @map("role_id")
  atribuidoPorId String?  @map("atribuido_por")
  atribuidoEm    DateTime @default(now()) @map("atribuido_em")
  user           User     @relation("UserToRoles", fields: [userId], references: [id], onDelete: Cascade)
  role           Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  atribuidoPor   User?    @relation("AtribuidoPor", fields: [atribuidoPorId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id                      String                   @id @default(uuid())
  recurso                 String
  acao                    String
  descricao               String?
  criadoEm                DateTime                 @default(now()) @map("criado_em")
  rolePermissions         RolePermission[]
  userPermissionOverrides UserPermissionOverride[]

  @@unique([recurso, acao])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermissionOverride {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  conceder     Boolean    @default(true)
  criadoEm     DateTime   @default(now()) @map("criado_em")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permission_overrides")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  ipAddress String?  @map("ip_address")
  expiraEm  DateTime @map("expira_em")
  criadoEm  DateTime @default(now()) @map("criado_em")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("user_sessions")
}

// ── Agenda ────────────────────────────────────────────────────────────────────

model Event {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  userId         String             @map("user_id")
  criadoPorId    String             @map("created_by")
  titulo         String
  descricao      String?
  tipo           EventType          @default(PESSOAL)
  cor            String?
  inicio         DateTime
  fim            DateTime?
  diaTodo        Boolean            @default(false) @map("dia_todo")
  origemTipo     String?            @map("origem_tipo")
  origemId       String?            @map("origem_id")
  confirmado     Boolean            @default(true)
  recorrencia    Recurrence?        @map("recorrencia")
  recorrenciaFim DateTime?          @map("recorrencia_fim")
  local          String?
  ata            String?            @db.Text
  criadoEm       DateTime           @default(now()) @map("criado_em")
  atualizadoEm   DateTime           @updatedAt @map("atualizado_em")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User               @relation("EventOwner", fields: [userId], references: [id])
  criadoPor      User               @relation("EventCreator", fields: [criadoPorId], references: [id])
  participants   EventParticipant[]

  @@index([organizationId, inicio])
  @@index([userId, inicio])
  @@index([criadoPorId])
  @@map("events")
}

model EventParticipant {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  userId  String @map("user_id")
  status  String @default("pendente")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_participants")
}

// ── CRM ───────────────────────────────────────────────────────────────────────

model Cliente {
  id               String            @id @default(uuid())
  organizationId   String            @map("organization_id")
  nome             String
  empresa          String?
  cargo            String?
  email            String?
  telefone         String?
  cnpj             String?
  site             String?
  cidade           String?
  estado           String?
  segmento         String?
  origem           String?
  statusLead       String            @default("ativo") @map("status_lead")
  notas            String?           @db.Text
  ativo            Boolean           @default(true)
  responsavelId    String?           @map("responsavel_id")
  saudeScore       Int               @default(100) @map("saude_score")
  portalToken      String?           @unique @map("portal_token")
  // Pipeline / Oportunidade
  tenantOrgId      String?           @unique @map("tenant_org_id")
  valorEstimado    Float?            @map("valor_estimado")
  probabilidade    Int?
  dataFechamento   DateTime?         @map("data_fechamento")
  criadoEm         DateTime          @default(now()) @map("criado_em")
  atualizadoEm     DateTime          @updatedAt @map("atualizado_em")
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responsavel      User?             @relation("ClienteResponsavel", fields: [responsavelId], references: [id])
  projetos         Project[]
  chamados         Chamado[]
  contratos        Contrato[]
  faturas          Fatura[]
  timeline         ClienteTimeline[]
  cadastroRequests CadastroRequest[]

  @@index([organizationId])
  @@map("clientes")
}

model Contrato {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  numero         Int?
  titulo         String          @default("")
  clienteId      String          @map("cliente_id")
  tipo           String          @default("servico")
  plano          String?
  status         String          @default("vigente")
  slaHoras       Int?            @map("sla_horas")
  vigenciaInicio DateTime?       @map("vigencia_inicio")
  vigenciaFim    DateTime?       @map("vigencia_fim")
  valor          Float?
  responsavelId  String?         @map("responsavel_id")
  ativo          Boolean         @default(true)
  observacoes    String?         @db.Text
  criadoEm       DateTime        @default(now()) @map("criado_em")
  atualizadoEm   DateTime        @updatedAt @map("atualizado_em")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cliente        Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  responsavel    User?           @relation("ContratoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  faturas        Fatura[]
  anexos         ContratoAnexo[]

  @@index([organizationId])
  @@index([clienteId])
  @@index([status])
  @@map("contratos")
}

model ClienteTimeline {
  id             String   @id @default(uuid())
  clienteId      String   @map("cliente_id")
  tipo           String
  titulo         String
  descricao      String?  @db.Text
  referenciaTipo String?  @map("referencia_tipo")
  referenciaId   String?  @map("referencia_id")
  userId         String?  @map("user_id")
  criadoEm       DateTime @default(now()) @map("criado_em")
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id])

  @@index([clienteId, criadoEm])
  @@map("cliente_timeline")
}

// ── Service Desk ──────────────────────────────────────────────────────────────

model SlaRegra {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  nome            String
  prioridade      String
  categoria       String?
  prazoRespostaH  Int          @default(4) @map("prazo_resposta_h")
  prazoResolucaoH Int          @default(24) @map("prazo_resolucao_h")
  ativo           Boolean      @default(true)
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chamados        Chamado[]

  @@unique([organizationId, prioridade, categoria])
  @@map("sla_regras")
}

model Chamado {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  numero             Int                 @default(autoincrement())
  titulo             String
  descricao          String              @db.Text
  status             String              @default("aberto")
  prioridade         String              @default("media")
  categoria          String?
  tags               String?
  solicitanteId      String              @map("solicitante_id")
  atendenteId        String?             @map("atendente_id")
  clienteId          String?             @map("cliente_id")
  slaHoras           Int?                @map("sla_horas")
  horasEstimadas     Float?              @map("horas_estimadas")
  skillRequeridaId   String?             @map("skill_requerida_id")
  nivelMinimo        String?             @map("nivel_minimo")
  slaRegraId         String?             @map("sla_regra_id")
  slaRespostaAt      DateTime?           @map("sla_resposta_at")
  slaResolucaoAt     DateTime?           @map("sla_resolucao_at")
  primeiraRespostaEm DateTime?           @map("primeira_resposta_em")
  resolvidoEm        DateTime?           @map("resolvido_em")
  fechadoEm          DateTime?           @map("fechado_em")
  avaliacao          Int?
  avaliacaoNota      String?             @map("avaliacao_nota") @db.Text
  criadoEm           DateTime            @default(now()) @map("criado_em")
  atualizadoEm       DateTime            @updatedAt @map("atualizado_em")
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  solicitante        User                @relation("ChamadoSolicitante", fields: [solicitanteId], references: [id])
  atendente          User?               @relation("ChamadoAtendente", fields: [atendenteId], references: [id])
  cliente            Cliente?            @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  slaRegra           SlaRegra?           @relation(fields: [slaRegraId], references: [id], onDelete: SetNull)
  comentarios        ChamadoComentario[]
  apontamentos       ApontamentoHoras[]
  auditorias         ChamadoAuditoria[]
  anexos             ChamadoAnexo[]
  watchers           ChamadoWatcher[]
  subtasks           ChamadoSubtask[]
  linksFrom          ChamadoLink[]       @relation("LinkFrom")
  linksTo            ChamadoLink[]       @relation("LinkTo")
  customValues       ChamadoCustomValue[]
  skillRequerida     Skill?              @relation("ChamadoSkill", fields: [skillRequeridaId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([skillRequeridaId])
  @@index([organizationId, prioridade])
  @@index([solicitanteId])
  @@index([atendenteId])
  @@index([organizationId, status, atendenteId])
  @@map("chamados")
}

// ── Anexos de Chamado ──────────────────────────────────────────────────────────
model ChamadoAnexo {
  id           String   @id @default(uuid())
  chamadoId    String   @map("chamado_id")
  uploaderId   String   @map("uploader_id")
  nomeOriginal String   @map("nome_original")
  nomeArquivo  String   @map("nome_arquivo")
  mimeType     String   @map("mime_type")
  tamanhoBytes Int      @map("tamanho_bytes")
  criadoEm    DateTime @default(now()) @map("criado_em")

  chamado  Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  uploader User    @relation("AnexoUploader", fields: [uploaderId], references: [id])

  @@index([chamadoId])
  @@map("chamado_anexos")
}

// ── Templates de Chamado ───────────────────────────────────────────────────────
model ChamadoTemplate {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  criadoPorId    String   @map("criado_por_id")
  nome           String
  titulo         String
  descricao      String?  @db.Text
  prioridade     String   @default("media")
  categoria      String?
  tags           String?
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  organization Organization @relation("OrgChamadoTemplates", fields: [organizationId], references: [id], onDelete: Cascade)
  criadoPor    User         @relation("ChamadoTemplateCriador", fields: [criadoPorId], references: [id])

  @@index([organizationId])
  @@map("chamado_templates")
}

model ChamadoComentario {
  id        String   @id @default(uuid())
  chamadoId String   @map("chamado_id")
  userId    String   @map("user_id")
  texto     String   @db.Text
  interno   Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")
  chamado   Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chamado_comentarios")
}

// ── Watchers / Seguidores ─────────────────────────────────────────────────────
// Usuarios que escolheram acompanhar um chamado sem ser solicitante/atendente.
// Recebem notificacoes em todas as interacoes publicas.
model ChamadoWatcher {
  id        String   @id @default(uuid())
  chamadoId String   @map("chamado_id")
  userId    String   @map("user_id")
  criadoEm  DateTime @default(now()) @map("criado_em")
  chamado   Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  user      User     @relation("ChamadoWatcher", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chamadoId, userId])
  @@index([userId])
  @@map("chamado_watchers")
}

// ── Subtasks / Checklist ─────────────────────────────────────────────────────
model ChamadoSubtask {
  id          String    @id @default(uuid())
  chamadoId   String    @map("chamado_id")
  titulo      String
  concluido   Boolean   @default(false)
  assigneeId  String?   @map("assignee_id")
  ordem       Int       @default(0)
  criadoEm    DateTime  @default(now()) @map("criado_em")
  concluidoEm DateTime? @map("concluido_em")
  chamado     Chamado   @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("ChamadoSubtask", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([chamadoId, ordem])
  @@map("chamado_subtasks")
}

// ── Links entre chamados ─────────────────────────────────────────────────────
// tipo: RELACIONADO | BLOQUEIA | BLOQUEADO_POR | DUPLICADO_DE
model ChamadoLink {
  id            String   @id @default(uuid())
  fromChamadoId String   @map("from_chamado_id")
  toChamadoId   String   @map("to_chamado_id")
  tipo          String
  criadoEm      DateTime @default(now()) @map("criado_em")
  criadoPorId   String?  @map("criado_por_id")
  fromChamado   Chamado  @relation("LinkFrom", fields: [fromChamadoId], references: [id], onDelete: Cascade)
  toChamado     Chamado  @relation("LinkTo",   fields: [toChamadoId],   references: [id], onDelete: Cascade)
  criadoPor     User?    @relation("ChamadoLinkCreator", fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@unique([fromChamadoId, toChamadoId, tipo])
  @@index([fromChamadoId])
  @@index([toChamadoId])
  @@map("chamado_links")
}

// ── Custom fields por categoria de chamado ───────────────────────────────────
// tipo: TEXT | TEXTAREA | NUMBER | DATE | SELECT | BOOLEAN
model ChamadoCustomField {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  categoria      String?  // null = aplica a todas as categorias
  label          String
  tipo           String
  obrigatorio    Boolean  @default(false)
  ordem          Int      @default(0)
  opcoesJson     Json?    @map("opcoes_json")
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         ChamadoCustomValue[]

  @@index([organizationId, categoria])
  @@map("chamado_custom_fields")
}

model ChamadoCustomValue {
  id        String  @id @default(uuid())
  chamadoId String  @map("chamado_id")
  fieldId   String  @map("field_id")
  valor     String  @db.Text
  chamado   Chamado            @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  field     ChamadoCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([chamadoId, fieldId])
  @@index([chamadoId])
  @@map("chamado_custom_values")
}

// Histórico/auditoria de chamados — registra ações importantes (criação, claim,
// atribuição, mudanças de status, transferências). Usado pela UI de timeline.
model ChamadoAuditoria {
  id        String   @id @default(uuid())
  chamadoId String   @map("chamado_id")
  userId    String?  @map("user_id")
  acao      String
  de        String?
  para      String?
  metadata  Json?
  criadoEm  DateTime @default(now()) @map("criado_em")
  chamado   Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([chamadoId])
  @@index([userId])
  @@index([acao])
  @@map("chamado_auditoria")
}

// ── Projetos ──────────────────────────────────────────────────────────────────

model Project {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  criadoPorId    String          @map("created_by")
  tipo           ProjectTipo     @default(PROJETO)
  clienteId      String?         @map("cliente_id")
  titulo         String
  descricao      String?
  status         ProjectStatus   @default(PLANEJAMENTO)
  prioridade     Priority        @default(MEDIA)
  valor          Float?
  dataInicio     DateTime?       @map("data_inicio")
  dataFim        DateTime?       @map("data_fim")
  progressoPct   Int             @default(0) @map("progresso_pct")
  cor            String?
  criadoEm       DateTime        @default(now()) @map("criado_em")
  atualizadoEm   DateTime        @updatedAt @map("atualizado_em")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  criadoPor      User            @relation("ProjectOwner", fields: [criadoPorId], references: [id])
  cliente        Cliente?        @relation(fields: [clienteId], references: [id])
  members        ProjectMember[]
  milestones     Milestone[]
  tasks          Task[]

  @@index([organizationId, status])
  @@index([criadoPorId])
  @@index([tipo])
  @@map("projects")
}

model ProjectMember {
  projectId    String   @map("project_id")
  userId       String   @map("user_id")
  papel        String   @default("membro")
  adicionadoEm DateTime @default(now()) @map("adicionado_em")
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  titulo    String
  descricao String?
  dataAlvo  DateTime @map("data_alvo")
  concluido Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@map("milestones")
}

model Task {
  id             String        @id @default(uuid())
  projectId      String        @map("project_id")
  milestoneId    String?       @map("milestone_id")
  assigneeId     String?       @map("assignee_id")
  criadoPorId    String        @map("created_by")
  titulo         String
  descricao      String?
  status         TaskStatus    @default(A_FAZER)
  prioridade     Priority      @default(MEDIA)
  dataInicio     DateTime?     @map("data_inicio")
  dataVencimento DateTime?     @map("data_vencimento")
  horasEstimadas Float?        @map("horas_estimadas")
  criadoEm       DateTime      @default(now()) @map("criado_em")
  atualizadoEm   DateTime      @updatedAt @map("atualizado_em")
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone      Milestone?    @relation(fields: [milestoneId], references: [id])
  assignee       User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  criadoPor      User          @relation("TaskCreator", fields: [criadoPorId], references: [id])
  comments       TaskComment[]

  @@index([projectId, status])
  @@index([assigneeId])
  @@map("tasks")
}

model TaskComment {
  id       String   @id @default(uuid())
  taskId   String   @map("task_id")
  userId   String   @map("user_id")
  conteudo String
  criadoEm DateTime @default(now()) @map("criado_em")
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

// ── Keep / Notes ──────────────────────────────────────────────────────────────

model Note {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  userId         String             @map("user_id")
  titulo         String?
  conteudo       String?
  cor            String?
  fixado         Boolean            @default(false)
  arquivado      Boolean            @default(false)
  lixeira        Boolean            @default(false)
  tipo           NoteType           @default(TEXTO)
  ordem          Int                @default(0)
  criadoEm       DateTime           @default(now()) @map("criado_em")
  atualizadoEm   DateTime           @updatedAt @map("atualizado_em")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id])
  labels         NoteLabelMap[]
  collaborators  NoteCollaborator[]
  checklists     Checklist[]

  @@index([organizationId, userId, arquivado, lixeira])
  @@map("notes")
}

model NoteLabel {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  userId         String         @map("user_id")
  nome           String
  cor            String?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id])
  notes          NoteLabelMap[]

  @@unique([organizationId, userId, nome])
  @@map("note_labels")
}

model NoteLabelMap {
  noteId  String    @map("note_id")
  labelId String    @map("label_id")
  note    Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  label   NoteLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([noteId, labelId])
  @@map("note_label_map")
}

model NoteCollaborator {
  noteId    String @map("note_id")
  userId    String @map("user_id")
  permissao String @default("leitura")
  note      Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([noteId, userId])
  @@map("note_collaborators")
}

model Checklist {
  id     String          @id @default(uuid())
  noteId String          @map("note_id")
  titulo String?
  ordem  Int             @default(0)
  note   Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  items  ChecklistItem[]

  @@map("checklists")
}

model ChecklistItem {
  id             String      @id @default(uuid())
  checklistId    String      @map("checklist_id")
  assigneeId     String?     @map("assignee_id")
  descricao      String
  concluido      Boolean     @default(false)
  dataVencimento DateTime?   @map("data_vencimento")
  ordem          Int         @default(0)
  criadoEm       DateTime    @default(now()) @map("criado_em")
  checklist      Checklist   @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee       User?       @relation("ChecklistAssignee", fields: [assigneeId], references: [id])
  dailyTasks     DailyTask[]

  @@map("checklist_items")
}

model DailyTask {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  checklistItemId String?        @map("checklist_item_id")
  titulo          String
  concluido       Boolean        @default(false)
  data            DateTime       @db.Date
  tipo            String         @default("TAREFA")
  prioridade      Int            @default(0)
  criadoEm        DateTime       @default(now()) @map("criado_em")
  user            User           @relation(fields: [userId], references: [id])
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id])

  @@index([userId, data])
  @@map("daily_tasks")
}

// ── Notifications / Audit ─────────────────────────────────────────────────────

model Notification {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  tipo           String
  titulo         String
  mensagem       String?
  referenciaTipo String?  @map("referencia_tipo")
  referenciaId   String?  @map("referencia_id")
  lida           Boolean  @default(false)
  criadoEm       DateTime @default(now()) @map("criado_em")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lida])
  @@index([tipo])
  @@index([criadoEm])
  @@map("notifications")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  userId         String?      @map("user_id")
  modulo         String?
  tabela         String
  registroId     String       @map("registro_id")
  acao           String
  descricao      String?
  dados          Json?
  ip             String?
  criadoEm       DateTime     @default(now()) @map("criado_em")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, criadoEm(sort: Desc)])
  @@index([userId])
  @@index([tabela, acao])
  @@map("audit_log")
}

// ── Automações ────────────────────────────────────────────────────────────────

model Automacao {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  nome           String
  descricao      String?
  trigger        String
  condicoes      Json                @default("[]")
  acoes          Json                @default("[]")
  ativo          Boolean             @default(true)
  totalExecucoes Int                 @default(0) @map("total_execucoes")
  ultimaExecucao DateTime?           @map("ultima_execucao")
  criadoEm       DateTime            @default(now()) @map("criado_em")
  atualizadoEm   DateTime            @updatedAt @map("atualizado_em")
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execucoes      AutomacaoExecucao[]

  @@index([organizationId])
  @@map("automacoes")
}

model AutomacaoExecucao {
  id          String    @id @default(uuid())
  automacaoId String    @map("automacao_id")
  trigger     String
  contextId   String    @map("context_id")
  resultado   String    @default("sucesso")
  detalhes    Json?
  criadoEm    DateTime  @default(now()) @map("criado_em")
  automacao   Automacao @relation(fields: [automacaoId], references: [id], onDelete: Cascade)

  @@index([automacaoId])
  @@index([criadoEm(sort: Desc)])
  @@map("automacao_execucoes")
}

// ── Webhooks ──────────────────────────────────────────────────────────────────

model Webhook {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  nome           String
  descricao      String?
  url            String
  evento         String
  headers        Json         @default("{}")
  secret         String?
  ativo          Boolean      @default(true)
  totalEnvios    Int          @default(0) @map("total_envios")
  ultimoEnvio    DateTime?    @map("ultimo_envio")
  ultimoStatus   Int?         @map("ultimo_status")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  atualizadoEm   DateTime     @updatedAt @map("atualizado_em")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           WebhookLog[]

  @@index([organizationId, evento])
  @@index([evento, ativo])
  @@map("webhooks")
}

model WebhookLog {
  id         String    @id @default(uuid())
  webhookId  String    @map("webhook_id")
  evento     String
  payload    Json?
  statusCode Int?      @map("status_code")
  response   String?   @db.Text
  sucesso    Boolean   @default(false)
  erro       String?   @db.Text
  criadoEm   DateTime  @default(now()) @map("criado_em")
  webhook    Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, criadoEm(sort: Desc)])
  @@map("webhook_logs")
}

// ── Ativos ────────────────────────────────────────────────────────────────────

model CategoriaAtivo {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  nome           String
  descricao      String?
  icone          String       @default("monitor")
  cor            String       @default("#7c3aed")
  ativo          Boolean      @default(true)
  criadoEm       DateTime     @default(now()) @map("criado_em")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ativos         Ativo[]

  @@unique([organizationId, nome])
  @@map("categorias_ativo")
}

model Ativo {
  id              String               @id @default(uuid())
  organizationId  String               @map("organization_id")
  codigo          String
  nome            String
  descricao       String?
  categoriaId     String?              @map("categoria_id")
  status          String               @default("ativo")
  marca           String?
  modelo          String?
  numeroSerie     String?              @map("numero_serie")
  localizacao     String?
  responsavelId   String?              @map("responsavel_id")
  setorId         String?              @map("setor_id")
  dataAquisicao   DateTime?            @map("data_aquisicao")
  valorAquisicao  Float?               @map("valor_aquisicao")
  dataGarantiaFim DateTime?            @map("data_garantia_fim")
  observacoes     String?              @db.Text
  ip              String?
  monitorar       Boolean              @default(false)
  online          Boolean?
  ultimoPing      DateTime?            @map("ultimo_ping")
  latenciaMs      Int?                 @map("latencia_ms")
  criadoEm        DateTime             @default(now()) @map("criado_em")
  atualizadoEm    DateTime             @updatedAt @map("atualizado_em")
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoria       CategoriaAtivo?      @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  responsavel     User?                @relation("AtivoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  setor           Setor?               @relation(fields: [setorId], references: [id], onDelete: SetNull)
  transferencias  TransferenciaAtivo[]
  pingLogs        PingLog[]
  veiculo         Veiculo?

  @@unique([organizationId, codigo])
  @@index([organizationId, status])
  @@index([organizationId, monitorar])
  @@index([responsavelId])
  @@map("ativos")
}

model PingLog {
  id             String       @id @default(uuid())
  ativoId        String       @map("ativo_id")
  organizationId String       @map("organization_id")
  online         Boolean
  latenciaMs     Int?         @map("latencia_ms")
  erro           String?
  criadoEm       DateTime     @default(now()) @map("criado_em")
  ativo          Ativo        @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([ativoId, criadoEm(sort: Desc)])
  @@index([organizationId, criadoEm(sort: Desc)])
  @@map("ping_logs")
}

model TransferenciaAtivo {
  id                String   @id @default(uuid())
  ativoId           String   @map("ativo_id")
  deResponsavelId   String?  @map("de_responsavel_id")
  paraResponsavelId String?  @map("para_responsavel_id")
  deSetorId         String?  @map("de_setor_id")
  paraSetorId       String?  @map("para_setor_id")
  motivo            String?
  realizadoPorId    String   @map("realizado_por_id")
  criadoEm          DateTime @default(now()) @map("criado_em")
  ativo             Ativo    @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  deResponsavel     User?    @relation("TransfDe", fields: [deResponsavelId], references: [id], onDelete: SetNull)
  paraResponsavel   User?    @relation("TransfPara", fields: [paraResponsavelId], references: [id], onDelete: SetNull)
  realizadoPor      User     @relation("TransfPor", fields: [realizadoPorId], references: [id])

  @@index([ativoId])
  @@map("transferencias_ativo")
}

// ── Gestão de Frotas ──────────────────────────────────────────────────────────
//
// Cadastro central: Veiculo. Todos os sub-cadastros vinculam-se por veiculoId.
// Padrão comum: exclusão lógica (deletedAt), auditoria de usuário (criadoPorId /
// atualizadoPorId — escalares; a trilha completa fica em audit_log), criadoEm e
// atualizadoEm. Tudo escopado por organizationId (multi-tenant).

model CategoriaVeiculo {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  nome           String
  descricao      String?
  icone          String       @default("car")
  cor            String       @default("#0ea5e9")
  ativo          Boolean      @default(true)
  criadoPorId    String?      @map("criado_por_id")
  atualizadoPorId String?     @map("atualizado_por_id")
  deletedAt      DateTime?    @map("deleted_at")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  atualizadoEm   DateTime     @updatedAt @map("atualizado_em")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  veiculos       Veiculo[]

  @@unique([organizationId, nome])
  @@index([organizationId, deletedAt])
  @@map("categorias_veiculo")
}

model Veiculo {
  id              String              @id @default(uuid())
  organizationId  String              @map("organization_id")
  codigo          String
  placa           String
  renavam         String?
  chassi          String?
  marca           String?
  modelo          String?
  anoFabricacao   Int?                @map("ano_fabricacao")
  anoModelo       Int?                @map("ano_modelo")
  cor             String?
  tipo            String              @default("carro")
  combustivel     String              @default("flex")
  categoriaId     String?             @map("categoria_id")
  status          String              @default("ativo")
  kmAtual         Int                 @default(0) @map("km_atual")
  horimetroAtual  Int?                @map("horimetro_atual")
  capacidadeTanque Float?             @map("capacidade_tanque")
  motoristaId     String?             @map("motorista_id")
  responsavelId   String?             @map("responsavel_id")
  centroCustoId   String?             @map("centro_custo_id")
  unidade         String?
  setorId         String?             @map("setor_id")
  ativoId         String?             @unique @map("ativo_id")
  dataAquisicao   DateTime?           @map("data_aquisicao")
  valorAquisicao  Float?              @map("valor_aquisicao")
  observacoes     String?             @db.Text
  criadoPorId     String?             @map("criado_por_id")
  atualizadoPorId String?             @map("atualizado_por_id")
  deletedAt       DateTime?           @map("deleted_at")
  criadoEm        DateTime            @default(now()) @map("criado_em")
  atualizadoEm    DateTime            @updatedAt @map("atualizado_em")
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoria       CategoriaVeiculo?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  motorista       Motorista?          @relation("VeiculoMotoristaPadrao", fields: [motoristaId], references: [id], onDelete: SetNull)
  responsavel     User?               @relation("VeiculoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  centroCusto     CentroCusto?        @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)
  setor           Setor?              @relation(fields: [setorId], references: [id], onDelete: SetNull)
  ativo           Ativo?              @relation(fields: [ativoId], references: [id], onDelete: SetNull)
  pneus           Pneu[]
  revisoes        RevisaoVeiculo[]
  manutencoes     ManutencaoVeiculo[]
  documentos      DocumentoVeiculo[]
  abastecimentos  Abastecimento[]
  condutores      VeiculoCondutor[]

  @@unique([organizationId, placa])
  @@unique([organizationId, codigo])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@map("veiculos")
}

model Motorista {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  nome            String
  cpf             String?
  matricula       String?
  departamento    String?
  cargo           String?
  cnh             String?
  categoriaCnh    String?      @map("categoria_cnh")
  cnhEmissao      DateTime?    @map("cnh_emissao")
  validadeCnh     DateTime?    @map("validade_cnh")
  orgaoEmissor    String?      @map("orgao_emissor")
  telefone        String?
  email           String?
  userId          String?      @map("user_id")
  status          String       @default("ativo")
  observacoes     String?      @db.Text
  criadoPorId     String?      @map("criado_por_id")
  atualizadoPorId String?      @map("atualizado_por_id")
  deletedAt       DateTime?    @map("deleted_at")
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  veiculos        Veiculo[]    @relation("VeiculoMotoristaPadrao")
  abastecimentos  Abastecimento[]
  condutorAssignments VeiculoCondutor[]
  renovacoes      MotoristaCnhRenovacao[]
  anexos          MotoristaAnexo[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
  @@map("motoristas")
}

model MotoristaCnhRenovacao {
  id                String       @id @default(uuid())
  organizationId    String       @map("organization_id")
  motoristaId       String       @map("motorista_id")
  numeroAnterior    String?      @map("numero_anterior")
  categoriaAnterior String?      @map("categoria_anterior")
  validadeAnterior  DateTime?    @map("validade_anterior")
