# Secrets — never commit
.env
.env.*
*.env
!*.env.example

# Dependencies
node_modules/
**/node_modules/

# Build outputs
backend/dist/
frontend/dist/
frontend/.next/
frontend/out/
frontend/tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# Deploy artifacts (tarballs gerados localmente)
*.tar
*.tar.gz

# Logs
logs/
*.log
npm-debug.log*

# Docker volumes / local data
backup/
*.dump
*.sql.gz

# SSL certificates (generated on server, never committed)
ssl/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Prisma generated (rebuilt on deploy)
backend/node_modules/.prisma/

# Claude AI internal files (settings pessoais ignorados, skills versionadas)
.claude/settings.json
.claude/settings.local.json
.claude/**/__pycache__/
.claude/**/*.pyc

# Misc
fm2.js

# saas — ignorar dados de runtime, mas versionar código
saas/tenants.json
saas/tenants/
saas/nginx-conf/
saas/backup/
saas/*.log
